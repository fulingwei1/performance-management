# 服务器配置
PORT=3001
NODE_ENV=development

# 本地数据库配置（默认使用本机 PostgreSQL，不依赖 Supabase）
# 启动方式：在项目根目录执行 docker compose up -d postgres
USE_MEMORY_DB=false
DATABASE_URL=postgresql://performance_user:performance123@localhost:5432/performance_db

# 仅测试/演示时才打开内存库；正式联调请保持 false
# USE_MEMORY_DB=true

# 可选：读缓存（ENABLE_CACHE=true 时启用，CACHE_TTL_MS 默认 5 分钟）
# ENABLE_CACHE=false
# CACHE_TTL_MS=300000

# JWT配置
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# 空库初始化员工临时密码：必须显式设置，不再内置 123456。
# 初始化导入的账号会被标记为首次登录必须修改密码。
INITIAL_EMPLOYEE_TEMP_PASSWORD=change_this_initial_temp_password

# AI服务配置（可选）
# Kimi (Moonshot) API Key - 用于AI辅助写作
KIMI_API_KEY=your_kimi_api_key_here
# 或者使用 MOONSHOT_API_KEY=your_api_key_here

# =============================================================================
# 薪资系统推送集成（可选）
# =============================================================================
# 薪资系统基地址（示例：本机运行 salary 后端）
SALARY_SYSTEM_BASE_URL=http://127.0.0.1:5000
# 薪资系统接收端校验 token（与薪资系统 SALARY_SYSTEM_PUSH_TOKEN / PERFORMANCE_PUSH_TOKEN 保持一致）
# 未配置时不会调用薪资系统绩效接口，避免无 token 写入或读取薪资数据。
SALARY_SYSTEM_PUSH_TOKEN=your_salary_push_token_here

# CORS 生产环境域名（部署时必须按实际域名/IP设置；不要依赖代码内置）
# 单个来源可用 CORS_ORIGIN，多个来源用英文逗号分隔的 CORS_ORIGINS
# CORS_ORIGIN=https://performance.example.com
# CORS_ORIGINS=https://performance.example.com,https://hr.example.com
# FRONTEND_URL=https://performance.example.com
# PERFORMANCE_SYSTEM_URL=https://performance.example.com/performance-management/login

# 请求限流（可选）
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=100
# LOGIN_RATE_LIMIT_MAX=50
# STRICT_LOGIN_RATE_LIMIT_MAX=5

# =============================================================================
# SMTP 邮件服务配置（可选）
# =============================================================================
# SMTP_HOST=smtp.example.com
# SMTP_PORT=465
# SMTP_USER=noreply@example.com
# SMTP_PASS=your_smtp_password_here
# SMTP_FROM=金凯博绩效系统 <noreply@example.com>
