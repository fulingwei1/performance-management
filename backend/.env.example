# 服务器配置
PORT=3001
NODE_ENV=development

# 本地数据库配置（默认使用本机 PostgreSQL，不依赖 Supabase）
# 启动方式：在项目根目录执行 docker compose up -d postgres
USE_MEMORY_DB=false
DATABASE_URL=postgresql://performance_user:performance123@localhost:5432/performance_db

# 仅测试/演示时才打开内存库；正式联调请保持 false
# USE_MEMORY_DB=true

# 可选：读缓存（ENABLE_CACHE=true 时启用，CACHE_TTL_MS 默认 5 分钟）
# ENABLE_CACHE=false
# CACHE_TTL_MS=300000

# JWT配置
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# 初始化管理员密码
ADMIN_DEFAULT_PASSWORD=123456

# AI服务配置（可选）
# Kimi (Moonshot) API Key - 用于AI辅助写作
KIMI_API_KEY=your_kimi_api_key_here
# 或者使用 MOONSHOT_API_KEY=your_api_key_here

# =============================================================================
# 薪资系统推送集成（可选）
# =============================================================================
# 薪资系统基地址（示例：本机运行 salary 后端）
SALARY_SYSTEM_BASE_URL=http://127.0.0.1:5000
# 薪资系统接收端校验 token（与薪资系统 PERFORMANCE_PUSH_TOKEN 保持一致）
SALARY_SYSTEM_PUSH_TOKEN=your_salary_push_token_here

# CORS 生产环境域名（部署时设置）
# CORS_ORIGIN=http://8.138.230.46
# FRONTEND_URL=http://8.138.230.46
