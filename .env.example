# 绩效管理系统环境变量配置
# 复制此文件为 .env 并填写真实值

# 数据库配置（必须）
POSTGRES_DB=performance_db
POSTGRES_USER=performance_user
POSTGRES_PASSWORD=please_change_me
DATABASE_URL=postgresql://performance_user:please_change_me@postgres:5432/performance_db

# JWT 密钥（必须，生产环境请使用 32 位以上随机字符串）
JWT_SECRET=please_change_to_a_long_random_secret

# 服务器定时/手动自动化任务专用令牌（必须随机生成；不要使用任何员工账号跑自动化）
AUTOMATION_SERVICE_TOKEN=please_change_to_a_long_random_automation_token

# 邮件服务配置（用于发送绩效通知邮件）
# 使用企业邮箱或 QQ/163 邮箱的 SMTP 服务
SMTP_HOST=smtp.exmail.qq.com
SMTP_PORT=465
SMTP_USER=noreply@yourcompany.com
SMTP_PASS=your_email_password_or_auth_code
SMTP_FROM=绩效管理系统 <noreply@yourcompany.com>

# AI API Key（可选，用于 AI 辅助功能）
KIMI_API_KEY=

# 企业微信应用消息/通讯录（可选）
WECOM_CORP_ID=
WECOM_SECRET=
WECOM_AGENT_ID=
WECOM_TEST_USER=

# 企业微信应用“接收消息”回调（可选；启用员工回复企业微信提交绩效总结）
# URL 填：https://你的域名或IP/performance-management/api/wecom/callback
WECOM_CALLBACK_TOKEN=
WECOM_ENCODING_AES_KEY=

# CORS 生产环境域名（部署时设置；多个来源用英文逗号分隔）
# FRONTEND_URL 可填完整前端地址；后端会自动取 origin 用于 CORS。
FRONTEND_URL=
CORS_ORIGIN=
CORS_ORIGINS=

# 请求限流（可选）
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
LOGIN_RATE_LIMIT_MAX=50
STRICT_LOGIN_RATE_LIMIT_MAX=5
